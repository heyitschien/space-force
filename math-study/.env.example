# Copy to .env.local and fill in. Never commit real secrets.
#
# Neon console project for this app: "asvab-math-study" (id flat-glade-66360442).
# Table public.test_attempts is created; get a fresh connection string from the Neon dashboard if needed.

# Neon Postgres (Vercel serverless / `vercel dev` — not exposed to the browser)
DATABASE_URL=

# Optional: require Authorization: Bearer <this> on POST /api/test-attempts
TEST_HISTORY_API_KEY=

# Optional client sync: deployment origin ending in /api, e.g. https://my-app.vercel.app/api
VITE_TEST_HISTORY_API_URL=

# If TEST_HISTORY_API_KEY is set on the server, set the same value here for the browser
VITE_TEST_HISTORY_API_KEY=
