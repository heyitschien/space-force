    {
      "quizId": "ratios-mastery",
      "title": "Ratios & Proportions Mastery Quiz",
      "topicId": "ratios",
      "quizType": "mastery",
      "questionCount": 15,
      "questions": [
        {
          "id": "ar-p2-012",
          "text": "If 3 garbage trucks can collect the trash of 24 homes in a day, how many trucks are needed to collect in 72 houses?",
          "options": [
            { "id": "A", "text": "9" },
            { "id": "B", "text": "3" },
            { "id": "C", "text": "24" },
            { "id": "D", "text": "8" }
          ],
          "correct": "A",
          "bucket": "ratios",
          "difficulty": "medium",
          "explanation": "Scale factor: 72 ÷ 24 = 3. Apply: 3 × 3 = 9 trucks."
        },
        {
          "id": "ar-p2-014",
          "text": "If a box has red and blue balls in a ratio of 3:4 red to blue, how many red balls are there if 80 blue balls are in the box?",
          "options": [
            { "id": "A", "text": "40" },
            { "id": "B", "text": "60" },
            { "id": "C", "text": "80" },
            { "id": "D", "text": "30" }
          ],
          "correct": "B",
          "bucket": "ratios",
          "difficulty": "hard",
          "explanation": "80 ÷ 4 = 20 groups. 3 × 20 = 60 red balls."
        },
        {
          "id": "ar-p2-018",
          "text": "An architect's floor plan uses 1/2 inch to represent one mile. What is the actual distance represented by 4 1/2 inches?",
          "options": [
            { "id": "A", "text": "9 miles" },
            { "id": "B", "text": "8 miles" },
            { "id": "C", "text": "7 miles" },
            { "id": "D", "text": "6 miles" }
          ],
          "correct": "A",
          "bucket": "ratios",
          "difficulty": "medium",
          "explanation": "4.5 ÷ 0.5 = 9 half-inches, so 9 miles."
        },
        {
          "id": "ar-p2-019",
          "text": "In the deck of cards, there are two spades, 3 hearts, 5 clubs, and 8 diamonds. What is the probability that Alan will pick out a spade?",
          "options": [
            { "id": "A", "text": "1/18" },
            { "id": "B", "text": "1/2" },
            { "id": "C", "text": "1/9" },
            { "id": "D", "text": "1/8" }
          ],
          "correct": "C",
          "bucket": "ratios",
          "difficulty": "hard",
          "explanation": "2 spades out of 2+3+5+8 = 18 cards. 2/18 = 1/9."
        },
        {
          "id": "rat-m-05",
          "text": "2 pencils cost $6. How much does 1 pencil cost?",
          "options": [
            { "id": "A", "text": "$2" },
            { "id": "B", "text": "$3" },
            { "id": "C", "text": "$4" },
            { "id": "D", "text": "$12" }
          ],
          "correct": "B",
          "bucket": "ratios",
          "difficulty": "easy",
          "explanation": "6 ÷ 2 = $3 per pencil."
        },
        {
          "id": "rat-m-06",
          "text": "5 workers complete 20 jobs. How many jobs does 1 worker complete?",
          "options": [
            { "id": "A", "text": "4" },
            { "id": "B", "text": "5" },
            { "id": "C", "text": "15" },
            { "id": "D", "text": "100" }
          ],
          "correct": "A",
          "bucket": "ratios",
          "difficulty": "easy",
          "explanation": "20 ÷ 5 = 4 jobs per worker."
        },
        {
          "id": "rat-m-07",
          "text": "4 machines make 80 parts. How many machines are needed for 200 parts?",
          "options": [
            { "id": "A", "text": "5" },
            { "id": "B", "text": "8" },
            { "id": "C", "text": "10" },
            { "id": "D", "text": "12" }
