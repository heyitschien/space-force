          "text": "A car travels 60 miles in 1.5 hours. How far does it travel in 5 hours?",
          "options": [
            { "id": "A", "text": "150 miles" },
            { "id": "B", "text": "180 miles" },
            { "id": "C", "text": "200 miles" },
            { "id": "D", "text": "240 miles" }
          ],
          "correct": "C",
          "bucket": "ratios",
          "difficulty": "medium",
          "explanation": "60 ÷ 1.5 = 40 mph. 40 × 5 = 200 miles."
        },
        {
          "id": "rat-m-11",
          "text": "3 pipes fill a tank in 6 hours. How long for 6 pipes?",
          "options": [
            { "id": "A", "text": "2 hours" },
            { "id": "B", "text": "3 hours" },
            { "id": "C", "text": "9 hours" },
            { "id": "D", "text": "12 hours" }
          ],
          "correct": "B",
          "bucket": "ratios",
          "difficulty": "hard",
          "explanation": "Twice the pipes = half the time. 6 ÷ 2 = 3 hours."
        },
        {
          "id": "rat-m-12",
          "text": "The ratio of boys to girls is 2:3. If there are 15 girls, how many boys?",
          "options": [
            { "id": "A", "text": "6" },
            { "id": "B", "text": "10" },
            { "id": "C", "text": "12" },
            { "id": "D", "text": "9" }
          ],
          "correct": "B",
          "bucket": "ratios",
          "difficulty": "medium",
          "explanation": "15 ÷ 3 = 5. 2 × 5 = 10 boys."
        },
        {
          "id": "rat-m-13",
          "text": "2 cups flour make 12 cookies. How many cups for 36 cookies?",
          "options": [
            { "id": "A", "text": "4" },
            { "id": "B", "text": "5" },
            { "id": "C", "text": "6" },
            { "id": "D", "text": "8" }
          ],
          "correct": "C",
          "bucket": "ratios",
          "difficulty": "easy",
          "explanation": "36 ÷ 12 = 3. 2 × 3 = 6 cups."
        },
        {
          "id": "rat-m-14",
          "text": "8 workers build a fence in 6 days. How many workers for 3 days?",
          "options": [
            { "id": "A", "text": "4" },
            { "id": "B", "text": "12" },
            { "id": "C", "text": "16" },
            { "id": "D", "text": "24" }
          ],
          "correct": "C",
          "bucket": "ratios",
          "difficulty": "hard",
          "explanation": "Half the time needs twice the workers. 8 × 2 = 16."
        },
        {
          "id": "rat-m-15",
          "text": "A truck carries 2 tons feeding 50 people for 5 days. How many people for 10 days?",
          "options": [
            { "id": "A", "text": "25" },
            { "id": "B", "text": "50" },
            { "id": "C", "text": "75" },
            { "id": "D", "text": "100" }
          ],
          "correct": "A",
          "bucket": "ratios",
          "difficulty": "hard",
          "explanation": "Same food, twice the time = half the people. 50 ÷ 2 = 25."
        }
      ]
